import GameTheory.Languages.OpenGame.Syntax

/-!
# Tests for Deterministic Open Games

These compilation tests exercise the typed wiring diagram for a two-move game
and check its equilibrium predicate by reduction.
-/

namespace OpenGames.Tests

open scoped OpenGames

/-- The standard two-move diagram: decide, copy the first move, decide again,
then deliver both players' cooutcomes through a costate. -/
def twoMove {A B : Type*} (u : A × B → ℝ × ℝ) :
    OpenGame Unit Unit Unit Unit :=
  OpenGame.decision Unit A ;ₒ
    OpenGame.copyWire A ℝ ;ₒ
    (OpenGame.idWire A ℝ ⊗ₒ OpenGame.decision A B) ;ₒ
    OpenGame.costate u

/-- Embed the usual leader action and follower contingent plan into the
strategy type generated by the wiring diagram. -/
def twoMoveStrategy {A B : Type*} (u : A × B → ℝ × ℝ)
    (first : A) (second : A → B) : (twoMove u).Strategy :=
  ((fun _ => first), ((), (((), second), ())))

/-- Plain sequential composition checks the follower only at the realized
history.  The first mover, however, compares deviations after the fixed
contingent follower plan has reacted to each alternative. -/
theorem twoMove_equilibrium_iff {A B : Type*} (u : A × B → ℝ × ℝ)
    (first : A) (second : A → B) :
    (twoMove u).IsEquilibriumIn () (fun _ => ())
        (twoMoveStrategy u first second) ↔
      (∀ a, (u (first, second first)).1 ≥ (u (a, second a)).1) ∧
      (∀ b, (u (first, second first)).2 ≥ (u (first, b)).2) := by
  simp [twoMove, twoMoveStrategy, OpenGame.seq, OpenGame.tensor,
    OpenGame.decision, OpenGame.copyWire, OpenGame.idWire, OpenGame.costate,
    OpenGame.ofLens, Lens.toOpenGame]

end OpenGames.Tests
