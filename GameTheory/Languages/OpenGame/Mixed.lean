import Math.FiniteProbabilityMassFunction

/-!
# Probabilistic open games

This file implements the finite-distribution `GProb` semantics of
Ghani--Kupke--Lambert--Nordvall Forsberg.  Play and coplay remain
deterministic; only the equilibrium predicate ranges over finite mixed
strategies.  Parallel and sequential composition admit independent joint
strategies.  Sequential composition uses the relational Kleisli lifting
`FinPMF.RelKleisli` at the random intermediate history.
-/

noncomputable section

namespace OpenGames

open Math

/-- A probabilistic open game.  The backward boundaries are intended to carry
`AvgAlgebra` instances when games are composed. -/
structure ProbOpenGame (X S Y R : Type*) where
  /-- Pure strategy profiles internal to the component. -/
  Strategy : Type*
  /-- Deterministic play for a pure strategy. -/
  play : Strategy → X → Y
  /-- Deterministic backward propagation of a cooutcome (coutility). -/
  coplay : Strategy → X → R → S
  /-- Selected finite mixed strategies in a deterministic context. -/
  IsEquilibriumIn : X → (Y → R) → FinPMF Strategy → Prop

namespace ProbOpenGame

variable {X S Y R Z Q : Type*}

/-- Expected value of an observable under a finite distribution. -/
def expect (μ : FinPMF α) (u : α → ℝ) : ℝ :=
  Math.Probability.expect μ.toPMF u

@[simp] theorem expect_pure (a : α) (u : α → ℝ) :
    expect (FinPMF.pure a) u = u a :=
  Math.Probability.expect_pure u a

/-- Sequential composition from the paper's Definition 12.  The first game
sees the average cooutcome generated by the second mixed strategy.  The
second mixed strategy must be selected by `D̄#` at the pushforward law of
intermediate histories. -/
def seq [AvgAlgebra R]
    (g : ProbOpenGame X S Y R) (h : ProbOpenGame Y R Z Q) :
    ProbOpenGame X S Z Q where
  Strategy := g.Strategy × h.Strategy
  play σ x := h.play σ.2 (g.play σ.1 x)
  coplay σ x q := g.coplay σ.1 x (h.coplay σ.2 (g.play σ.1 x) q)
  IsEquilibriumIn x k φ :=
    let φg := FinPMF.map Prod.fst φ
    let φh := FinPMF.map Prod.snd φ
    φ = FinPMF.product φg φh ∧
      g.IsEquilibriumIn x
        (fun y => AvgAlgebra.avg
          (FinPMF.map
            (fun σh => h.coplay σh y (k (h.play σh y))) φh)) φg ∧
      FinPMF.RelKleisli
        (fun y => {ψ | h.IsEquilibriumIn y k ψ})
        (FinPMF.map (fun σg => g.play σg x) φg) φh

/-- Parallel composition from the paper's Definition 5.  Equilibrium joint
strategies are required to factor into their marginals. -/
def tensor {X' S' Y' R' : Type*} [AvgAlgebra R] [AvgAlgebra R']
    (g : ProbOpenGame X S Y R) (h : ProbOpenGame X' S' Y' R') :
    ProbOpenGame (X × X') (S × S') (Y × Y') (R × R') where
  Strategy := g.Strategy × h.Strategy
  play σ x := (g.play σ.1 x.1, h.play σ.2 x.2)
  coplay σ x r := (g.coplay σ.1 x.1 r.1, h.coplay σ.2 x.2 r.2)
  IsEquilibriumIn x k φ :=
    let φg := FinPMF.map Prod.fst φ
    let φh := FinPMF.map Prod.snd φ
    φ = FinPMF.product φg φh ∧
      g.IsEquilibriumIn x.1
        (fun y => AvgAlgebra.avg
          (FinPMF.map
            (fun σh => (k (y, h.play σh x.2)).1) φh)) φg ∧
      h.IsEquilibriumIn x.2
        (fun y' => AvgAlgebra.avg
          (FinPMF.map
            (fun σg => (k (g.play σg x.1, y')).2) φg)) φh

end ProbOpenGame

scoped[OpenGames] infixr:90 " ;ₚ " => ProbOpenGame.seq
scoped[OpenGames] infixr:88 " ⊗ₚ " => ProbOpenGame.tensor

namespace ProbOpenGame

variable {X S Y R Z Q : Type*}

/-- The sequential equilibrium predicate reduces cleanly on an explicitly
independent strategy. -/
theorem seq_isEquilibriumIn_product_iff [AvgAlgebra R]
    (g : ProbOpenGame X S Y R) (h : ProbOpenGame Y R Z Q)
    (x : X) (k : Z → Q) (φg : FinPMF g.Strategy)
    (φh : FinPMF h.Strategy) :
    (g ;ₚ h).IsEquilibriumIn x k (FinPMF.product φg φh) ↔
      g.IsEquilibriumIn x
        (fun y => AvgAlgebra.avg
          (FinPMF.map
            (fun σh => h.coplay σh y (k (h.play σh y))) φh)) φg ∧
      FinPMF.RelKleisli
        (fun y => {ψ | h.IsEquilibriumIn y k ψ})
        (FinPMF.map (fun σg => g.play σg x) φg) φh := by
  simp [seq]

/-- If the later equilibrium predicate is independent of the incoming
history, `D̄#` has an exact and simple meaning: the later mixed strategy lies
in the finite convex closure of the selected set.  This is the
history-independent case of the semantic question left open after Example 13
of the paper. -/
theorem seq_historyIndependent_iff [AvgAlgebra R]
    (g : ProbOpenGame X S Y R) (h : ProbOpenGame Y R Z Q)
    (x : X) (k : Z → Q) (φg : FinPMF g.Strategy)
    (φh : FinPMF h.Strategy) (E : Set (FinPMF h.Strategy))
    (hE : ∀ y ψ, h.IsEquilibriumIn y k ψ ↔ ψ ∈ E) :
    (g ;ₚ h).IsEquilibriumIn x k (FinPMF.product φg φh) ↔
      g.IsEquilibriumIn x
        (fun y => AvgAlgebra.avg
          (FinPMF.map
            (fun σh => h.coplay σh y (k (h.play σh y))) φh)) φg ∧
      φh ∈ FinPMF.convexClosure E := by
  rw [seq_isEquilibriumIn_product_iff]
  apply and_congr_right
  intro _hg
  rw [show (fun y => {ψ | h.IsEquilibriumIn y k ψ}) = (fun _ => E) by
    funext y
    ext ψ
    exact hE y ψ]
  exact FinPMF.relKleisli_const_iff E _ _

/-- The parallel equilibrium predicate reduces cleanly on an independent
strategy. -/
theorem tensor_isEquilibriumIn_product_iff
    {X' S' Y' R' : Type*} [AvgAlgebra R] [AvgAlgebra R']
    (g : ProbOpenGame X S Y R) (h : ProbOpenGame X' S' Y' R')
    (x : X × X') (k : Y × Y' → R × R')
    (φg : FinPMF g.Strategy) (φh : FinPMF h.Strategy) :
    (g ⊗ₚ h).IsEquilibriumIn x k (FinPMF.product φg φh) ↔
      g.IsEquilibriumIn x.1
        (fun y => AvgAlgebra.avg
          (FinPMF.map
            (fun σh => (k (y, h.play σh x.2)).1) φh)) φg ∧
      h.IsEquilibriumIn x.2
        (fun y' => AvgAlgebra.avg
          (FinPMF.map
            (fun σg => (k (g.play σg x.1, y')).2) φg)) φh := by
  simp [tensor]

/-- Strategically trivial probabilistic wiring. -/
def ofLens (view : X → Y) (update : X → R → S) :
    ProbOpenGame X S Y R where
  Strategy := Unit
  play _ := view
  coplay _ := update
  IsEquilibriumIn _ _ _ := True

/-- Identity wiring. -/
def idWire (X S : Type*) : ProbOpenGame X S X S :=
  ofLens id fun _ s => s

/-- Every equilibrium set of `g` is closed under finite barycenters.  Exact
`D̄#` composition needs this semantic property for the left identity law. -/
def HasConvexEquilibria (g : ProbOpenGame X S Y R) : Prop :=
  ∀ (x : X) (k : Y → R),
    FinPMF.convexClosure {μ | g.IsEquilibriumIn x k μ} ⊆
      {μ | g.IsEquilibriumIn x k μ}

/-- Saturate every equilibrium set under finite barycenters. -/
def convexify (g : ProbOpenGame X S Y R) : ProbOpenGame X S Y R where
  Strategy := g.Strategy
  play := g.play
  coplay := g.coplay
  IsEquilibriumIn x k μ :=
    μ ∈ FinPMF.convexClosure {ψ | g.IsEquilibriumIn x k ψ}

theorem convexify_hasConvexEquilibria (g : ProbOpenGame X S Y R) :
    HasConvexEquilibria (convexify g) := by
  intro x k μ hμ
  change μ ∈ FinPMF.convexClosure
    (FinPMF.convexClosure {ψ | g.IsEquilibriumIn x k ψ}) at hμ
  change μ ∈ FinPMF.convexClosure {ψ | g.IsEquilibriumIn x k ψ}
  rwa [FinPMF.convexClosure_idempotent] at hμ

@[simp] theorem convexify_isEquilibriumIn_iff
    (g : ProbOpenGame X S Y R) (x : X) (k : Y → R)
    (μ : FinPMF g.Strategy) :
    (convexify g).IsEquilibriumIn x k μ ↔
      μ ∈ FinPMF.convexClosure {ψ | g.IsEquilibriumIn x k ψ} :=
  Iff.rfl

/-- Composing an identity before a game convexifies the game's equilibrium
set.  This is exact, not merely an inclusion. -/
theorem idWire_seq_isEquilibriumIn_product_iff [AvgAlgebra S]
    (g : ProbOpenGame X S Y R) (x : X) (k : Y → R)
    (φ : FinPMF g.Strategy) :
    (idWire X S ;ₚ g).IsEquilibriumIn x k
        (FinPMF.product (FinPMF.pure ()) φ) ↔
      φ ∈ FinPMF.convexClosure {ψ | g.IsEquilibriumIn x k ψ} := by
  rw [seq_isEquilibriumIn_product_iff]
  simp only [idWire, ofLens, true_and, FinPMF.map_pure]
  exact FinPMF.relKleisli_pure_iff
    (fun y => {ψ | g.IsEquilibriumIn y k ψ}) x φ

/-- Thus the unrestricted left composite agrees exactly with the convexified
game, identifying convex saturation as the minimal unit-law repair. -/
theorem idWire_seq_isEquilibriumIn_product_iff_convexify [AvgAlgebra S]
    (g : ProbOpenGame X S Y R) (x : X) (k : Y → R)
    (φ : FinPMF g.Strategy) :
    (idWire X S ;ₚ g).IsEquilibriumIn x k
        (FinPMF.product (FinPMF.pure ()) φ) ↔
      (convexify g).IsEquilibriumIn x k φ :=
  idWire_seq_isEquilibriumIn_product_iff g x k φ

/-- The left identity law holds on games whose equilibrium sets are already
closed under the convexification performed by `D̄#`. -/
theorem idWire_seq_isEquilibriumIn_product_iff_of_convex [AvgAlgebra S]
    (g : ProbOpenGame X S Y R) (hg : HasConvexEquilibria g)
    (x : X) (k : Y → R) (φ : FinPMF g.Strategy) :
    (idWire X S ;ₚ g).IsEquilibriumIn x k
        (FinPMF.product (FinPMF.pure ()) φ) ↔
      g.IsEquilibriumIn x k φ := by
  rw [idWire_seq_isEquilibriumIn_product_iff]
  constructor
  · intro hφ
    exact hg x k hφ
  · intro hφ
    exact FinPMF.subset_convexClosure _ hφ

/-- Composing a game with an identity on the right preserves equilibrium
without an additional closure hypothesis. -/
theorem seq_idWire_isEquilibriumIn_product_iff [AvgAlgebra R]
    (g : ProbOpenGame X S Y R) (x : X) (k : Y → R)
    (φ : FinPMF g.Strategy) :
    (g ;ₚ idWire Y R).IsEquilibriumIn x k
        (FinPMF.product φ (FinPMF.pure ())) ↔
      g.IsEquilibriumIn x k φ := by
  rw [seq_isEquilibriumIn_product_iff]
  constructor
  · rintro ⟨hg, _hid⟩
    simpa [idWire, ofLens] using hg
  · intro hg
    constructor
    · simpa [idWire, ofLens] using hg
    · apply FinPMF.relKleisli_of_forall_mem
      intro y _hy
      exact Set.mem_univ _

/-- A mixed decision after observing `X`.  A distribution over contingent
pure plans is selected exactly when no alternative distribution has greater
expected payoff at the realized history. -/
def decision (X Y : Type*) : ProbOpenGame X Unit Y ℝ where
  Strategy := X → Y
  play σ x := σ x
  coplay _ _ _ := ()
  IsEquilibriumIn x k μ :=
    ∀ ν : FinPMF (X → Y),
      expect ν (fun σ => k (σ x)) ≤ expect μ (fun σ => k (σ x))

/-- Mixed optimality can be tested using pure constant deviations. -/
theorem decision_isEquilibriumIn_iff (X Y : Type*) (x : X) (k : Y → ℝ)
    (μ : FinPMF (X → Y)) :
    (decision X Y).IsEquilibriumIn x k μ ↔
      ∀ y, k y ≤ expect μ (fun σ => k (σ x)) := by
  constructor
  · intro h y
    simpa using h (FinPMF.pure fun _ => y)
  · intro h ν
    exact FinPMF.expect_le_const ν (fun σ => k (σ x))
      (expect μ fun σ => k (σ x)) fun σ => h (σ x)

theorem decision_hasConvexEquilibria (X Y : Type*) :
    HasConvexEquilibria (decision X Y) := by
  intro x k μ hμ
  rcases hμ with ⟨θ, hθ, rfl⟩
  intro ν
  calc
    expect ν (fun σ => k (σ x)) =
        Math.Probability.expect θ.toPMF
          (fun _ => expect ν (fun σ => k (σ x))) := by
      symm
      exact Math.Probability.expect_const _ _
    _ ≤ Math.Probability.expect θ.toPMF
          (fun ψ => expect ψ (fun σ => k (σ x))) := by
      apply FinPMF.expect_mono_on_support
      intro ψ hψ
      exact hθ hψ ν
    _ = expect (FinPMF.join θ) (fun σ => k (σ x)) := by
      exact (FinPMF.expect_bind θ id (fun σ => k (σ x))).symm

/-- State-free decisions use actions themselves as pure strategies, avoiding
an inessential `Unit → Y` wrapper in normal-form bridges. -/
def actionDecision (Y : Type*) : ProbOpenGame Unit Unit Y ℝ where
  Strategy := Y
  play y _ := y
  coplay _ _ _ := ()
  IsEquilibriumIn _ k μ :=
    ∀ ν : FinPMF Y, expect ν k ≤ expect μ k

theorem actionDecision_isEquilibriumIn_iff (Y : Type*) (k : Y → ℝ)
    (μ : FinPMF Y) :
    (actionDecision Y).IsEquilibriumIn () k μ ↔
      ∀ y, k y ≤ expect μ k := by
  constructor
  · intro h y
    simpa using h (FinPMF.pure y)
  · intro h ν
    exact FinPMF.expect_le_const ν k (expect μ k) h

theorem actionDecision_hasConvexEquilibria (Y : Type*) :
    HasConvexEquilibria (actionDecision Y) := by
  intro _x k μ hμ
  rcases hμ with ⟨θ, hθ, rfl⟩
  intro ν
  calc
    expect ν k = Math.Probability.expect θ.toPMF (fun _ => expect ν k) := by
      symm
      exact Math.Probability.expect_const _ _
    _ ≤ Math.Probability.expect θ.toPMF (fun ψ => expect ψ k) := by
      apply FinPMF.expect_mono_on_support
      intro ψ hψ
      exact hθ hψ ν
    _ = expect (FinPMF.join θ) k := by
      exact (FinPMF.expect_bind θ id k).symm

/-! ## Two-player normal-form recovery -/

/-- The usual two-player mixed-Nash inequalities, stated directly for
finite-support marginals on arbitrary action carriers. -/
def IsMixedNash2 {A B : Type*} (u : A × B → ℝ × ℝ)
    (μ : FinPMF A) (ν : FinPMF B) : Prop :=
  (∀ μ' : FinPMF A,
    expect (FinPMF.product μ' ν) (fun p => (u p).1) ≤
      expect (FinPMF.product μ ν) (fun p => (u p).1)) ∧
  (∀ ν' : FinPMF B,
    expect (FinPMF.product μ ν') (fun p => (u p).2) ≤
      expect (FinPMF.product μ ν) (fun p => (u p).2))

/-- Tensoring two mixed decisions recovers exactly the ordinary independent
two-player mixed-Nash predicate. -/
theorem actionDecision_tensor_isEquilibriumIn_iff_isMixedNash2
    {A B : Type*} (u : A × B → ℝ × ℝ)
    (μ : FinPMF A) (ν : FinPMF B) :
    (actionDecision A ⊗ₚ actionDecision B).IsEquilibriumIn ((), ()) u
        (FinPMF.product μ ν) ↔
      IsMixedNash2 u μ ν := by
  rw [tensor_isEquilibriumIn_product_iff]
  simp only [actionDecision]
  unfold IsMixedNash2 expect
  simp only [AvgAlgebra.avg_map_real]
  constructor
  · rintro ⟨hμ, hν⟩
    constructor
    · intro μ'
      simpa only [FinPMF.expect_product] using hμ μ'
    · intro ν'
      rw [FinPMF.expect_product_swap, FinPMF.expect_product_swap]
      exact hν ν'
  · rintro ⟨hμ, hν⟩
    constructor
    · intro μ'
      simpa only [FinPMF.expect_product] using hμ μ'
    · intro ν'
      have h := hν ν'
      rw [FinPMF.expect_product_swap, FinPMF.expect_product_swap] at h
      exact h

end ProbOpenGame

end OpenGames
