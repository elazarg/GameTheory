/-- If the approximate shifted-cell cover avoids the forbidden faces, KKM gives
a simplex point and a permutation whose assigned weak-preference sets are within
mesh distance `n / M`. -/
theorem stromquistApproxPreferenceWitnesses
    (hn : 0 < n)
    (α : Fin n → ℝ)
    (hα : Pairwise fun j k : Fin n => Irrational (α j - α k))
    (M : ℕ) (hM : 0 < M)
    (hface :
      ∀ i, Math.FixedPoint.simplexFaceOpp i ⊆
        (stromquistApproxPreferenceUnion n μ M α i)ᶜ) :
    ∃ (x : Fin n → ℝ) (_ : x ∈ stdSimplex ℝ (Fin n)) (perm : Fin n ≃ Fin n),
      ∀ j : Fin n, ∃ y ∈ stromquistWeakPreferenceSet n μ (perm.symm j) j,
        y ∈ stdSimplex ℝ (Fin n) ∧ dist x y ≤ n / M := by
  obtain ⟨x, hxS, hxU⟩ := Math.FixedPoint.kkm_open_cover hn
    (stromquistApproxPreferenceUnion n μ M α)
    (stromquistApproxPreferenceUnion_open n μ M α)
    hface
    (stromquistApproxPreferenceUnion_covers n μ hn α hα M hM)
  obtain ⟨assign, hassign⟩ :
      ∃ assign : Fin n → Fin n,
        ∀ i, x ∈ stromquistApproxUniquePreferenceSet n μ M α i (assign i) := by
    have h_choice : ∀ i, ∃ j, x ∈ stromquistApproxUniquePreferenceSet n μ M α i j := by
      intro i
      exact Set.mem_iUnion.mp (hxU i)
    choose assign hassign using h_choice
    exact ⟨assign, hassign⟩
  have h_inj : Function.Injective assign := by
    intro i i' heq
    by_contra hii'
    have hdisj := disjoint_stromquistApproxUniquePreferenceSet n μ M α (assign i) i i' hii'
    exact Set.disjoint_left.mp hdisj (hassign i) (by simpa [heq] using hassign i')
  let perm : Fin n ≃ Fin n :=
    Equiv.ofBijective assign ⟨h_inj, Finite.injective_iff_surjective.mp h_inj⟩
  refine ⟨x, hxS, perm, ?_⟩
  intro j
  have hcellUnion : x ∈
      stromquistApproxUniquePreferenceSet n μ M α (perm.symm j) j := by
    have h := hassign (perm.symm j)
    have hassign_eq : assign (perm.symm j) = j := perm.apply_symm_apply j
    rwa [hassign_eq] at h
  simp only [stromquistApproxUniquePreferenceSet, Set.mem_iUnion] at hcellUnion
  obtain ⟨p, hp⟩ := hcellUnion
  by_cases howner : stromquistCellOwner n μ M α j p = some (perm.symm j)
  · have hxcell : x ∈ stromquistShiftedCell n M α j p := by
      rwa [if_pos howner] at hp
    have hhit := stromquistCellOwner_eq_some_imp_hits n μ M α j (perm.symm j) p howner
    simp only [stromquistCellHits] at hhit
    obtain ⟨y, ⟨⟨hycell, hyS⟩, hyPref⟩⟩ := hhit
    exact ⟨y, hyPref, hyS,
      stromquist_same_shiftedCell_dist_le n hn M hM α j p x y hxcell hycell hxS hyS⟩
  · have : x ∈ (∅ : Set (Fin n → ℝ)) := by
      rwa [if_neg howner] at hp
    exact this.elim

/-- For all sufficiently fine meshes, the approximate shifted-cell preference
unions avoid the forbidden faces. -/
theorem stromquistApproxPreferenceUnion_eventually_avoids_faces
    (hn : 0 < n)
    (α : Fin n → ℝ)
    (hpos : ∀ j : Fin n, 0 < μ j (Set.Ico 0 1)) :
    ∃ M₀ : ℕ, 0 < M₀ ∧ ∀ M ≥ M₀, ∀ i,
      Math.FixedPoint.simplexFaceOpp i ⊆
        (stromquistApproxPreferenceUnion n μ M α i)ᶜ := by
  have h_dist_pos (i j : Fin n) :
      ∃ δ > 0, ∀ x ∈ Math.FixedPoint.simplexFaceOpp i,
        ∀ y ∈ stromquistWeakPreferenceSet n μ i j ∩ stdSimplex ℝ (Fin n),
          δ ≤ dist x y := by
    let F : Set (Fin n → ℝ) := Math.FixedPoint.simplexFaceOpp i
    let P : Set (Fin n → ℝ) := stromquistWeakPreferenceSet n μ i j ∩ stdSimplex ℝ (Fin n)
    have hF_compact : IsCompact F := by
      have hF_closed : IsClosed F :=
        (isClosed_eq (continuous_apply i) continuous_const).inter
          (isClosed_stdSimplex ℝ (Fin n))
      exact (isCompact_stdSimplex ℝ (Fin n)).of_isClosed_subset hF_closed
        (by intro x hx; exact hx.2)
    have hP_closed : IsClosed P :=
      (stromquistWeakPreferenceSet_closed n μ i j).inter (isClosed_stdSimplex ℝ (Fin n))
    have hdisj : Disjoint F P := by
      rw [Set.disjoint_left]
      intro x hxF hxP
      have hnot := Set.eq_empty_iff_forall_notMem.mp
        (stromquistWeakPreferenceSet_avoids_face n μ i j (hpos j)) x
      exact hnot ⟨hxP.1, hxF⟩
    obtain ⟨r, hrpos, hr⟩ := Metric.exists_pos_forall_lt_edist hF_compact hP_closed hdisj
    refine ⟨(r : ℝ), by exact_mod_cast hrpos, fun x hx y hy => ?_⟩
    have hlt := hr x hx y hy
    rw [edist_dist] at hlt
    exact le_of_lt (ENNReal.toReal_lt_of_lt_ofReal hlt)
  choose δ hδ_pos hδ using h_dist_pos
  let i0 : Fin n := ⟨0, hn⟩
  let δs : Finset ℝ := Finset.univ.image (fun p : Fin n × Fin n => δ p.1 p.2)
  have hδs_nonempty : δs.Nonempty :=
    ⟨δ i0 i0, Finset.mem_image.mpr ⟨(i0, i0), Finset.mem_univ _, rfl⟩⟩
  let δmin : ℝ := δs.min' hδs_nonempty
  have hδmin_pos : 0 < δmin := by
    have hmem := Finset.min'_mem δs hδs_nonempty
    obtain ⟨p, _, hp⟩ := Finset.mem_image.mp hmem
    change 0 < δs.min' hδs_nonempty
    rw [← hp]
    exact hδ_pos p.1 p.2
  have hδmin_le : ∀ i j : Fin n, δmin ≤ δ i j := by
    intro i j
    exact Finset.min'_le δs (δ i j)
      (Finset.mem_image.mpr ⟨(i, j), Finset.mem_univ _, rfl⟩)
  obtain ⟨M₀, hM₀_pos, hM₀_bound⟩ :
      ∃ M₀ : ℕ, 0 < M₀ ∧ ∀ M ≥ M₀, (n : ℝ) / (M : ℝ) < δmin := by
    refine ⟨⌊(n : ℝ) / δmin⌋₊ + 1, Nat.succ_pos _, fun M hM => ?_⟩
    have hMpos : (0 : ℝ) < M := by
      exact_mod_cast lt_of_lt_of_le (Nat.succ_pos _) hM
    rw [div_lt_iff₀ hMpos]
    have hceil : (n : ℝ) / δmin < (⌊(n : ℝ) / δmin⌋₊ + 1 : ℕ) := by
      simpa [Nat.cast_add, Nat.cast_one] using
        Nat.lt_floor_add_one ((n : ℝ) / δmin)
    have hMreal : ((⌊(n : ℝ) / δmin⌋₊ + 1 : ℕ) : ℝ) ≤ M := by
      exact_mod_cast hM
    calc
      (n : ℝ) = ((n : ℝ) / δmin) * δmin := by
        rw [div_mul_cancel₀ _ hδmin_pos.ne']
      _ < ((⌊(n : ℝ) / δmin⌋₊ + 1 : ℕ) : ℝ) * δmin :=
        mul_lt_mul_of_pos_right hceil hδmin_pos
      _ ≤ (M : ℝ) * δmin :=
        mul_le_mul_of_nonneg_right hMreal hδmin_pos.le
      _ = δmin * (M : ℝ) := by ring
  refine ⟨M₀, hM₀_pos, fun M hM i x hxface hxU => ?_⟩
  obtain ⟨j, hxB⟩ := Set.mem_iUnion.mp hxU
  obtain ⟨p, hp⟩ := Set.mem_iUnion.mp hxB
  by_cases howner : stromquistCellOwner n μ M α j p = some i
  · have hxcell : x ∈ stromquistShiftedCell n M α j p := by
      rwa [if_pos howner] at hp
    have hhit := stromquistCellOwner_eq_some_imp_hits n μ M α j i p howner
    simp only [stromquistCellHits] at hhit
    obtain ⟨y, ⟨⟨hycell, hyS⟩, hyPref⟩⟩ := hhit
    have hMpos : 0 < M := lt_of_lt_of_le hM₀_pos hM
    have hdist_le := stromquist_same_shiftedCell_dist_le n hn M hMpos α j p x y
      hxcell hycell hxface.2 hyS
    have hsep : δmin ≤ dist x y :=
      (hδmin_le i j).trans (hδ i j x hxface y ⟨hyPref, hyS⟩)
    linarith [hM₀_bound M hM, hdist_le, hsep]
  · have : x ∈ (∅ : Set (Fin n → ℝ)) := by
      rwa [if_neg howner] at hp
    exact this.elim

/-- Compactness limit for Stromquist witnesses: if every positive tolerance has
an approximate simplex point and permutation with nearby preference witnesses,
then there is an exact common weak-preference point. -/
theorem stromquist_preferenceEquiv_exists_of_approx
    (h : ∀ ε > (0 : ℝ), ∃ (x : Fin n → ℝ) (_ : x ∈ stdSimplex ℝ (Fin n))
        (e : Fin n ≃ Fin n),
      ∀ j : Fin n, ∃ y ∈ stromquistWeakPreferenceSet n μ (e.symm j) j,
        dist x y < ε) :
    ∃ (x : Fin n → ℝ) (_ : x ∈ stdSimplex ℝ (Fin n)) (e : Fin n ≃ Fin n),
      ∀ j : Fin n, x ∈ stromquistWeakPreferenceSet n μ (e.symm j) j := by
  have h_compact : IsCompact (stdSimplex ℝ (Fin n)) :=
    isCompact_stdSimplex ℝ (Fin n)
  have h_seq : ∃ (x : ℕ → Fin n → ℝ), (∀ k, x k ∈ stdSimplex ℝ (Fin n)) ∧
      ∃ (e : ℕ → Fin n ≃ Fin n),
        ∀ k, ∀ j, ∃ y ∈ stromquistWeakPreferenceSet n μ ((e k).symm j) j,
          dist (x k) y < 1 / (k + 1 : ℝ) := by
    choose x hx e he using h
    refine ⟨fun k => x (1 / (k + 1 : ℝ)) (by positivity), ?_,
      fun k => e (1 / (k + 1 : ℝ)) (by positivity), ?_⟩
    · intro k
      exact hx _ _
    · intro k j
      exact he _ _ j
  obtain ⟨x, hx_seq, e, he⟩ := h_seq
  obtain ⟨x_star, hx_star, subseq, hsubseq_mono, hsubseq_tendsto⟩ :
      ∃ x_star ∈ stdSimplex ℝ (Fin n), ∃ subseq : ℕ → ℕ,
        StrictMono subseq ∧ Filter.Tendsto (fun r => x (subseq r)) Filter.atTop
          (nhds x_star) := by
    exact h_compact.tendsto_subseq hx_seq
  have h_e_const : ∃ e₀ : Fin n ≃ Fin n, Set.Infinite {r | e (subseq r) = e₀} := by
    by_contra h_contra
    push Not at h_contra
    exact Set.infinite_univ
      (Set.Finite.subset
        (Set.Finite.biUnion (Set.toFinite (Set.univ : Set (Fin n ≃ Fin n)))
          fun e₀ _ => h_contra e₀)
        fun r _ => by simp)
  obtain ⟨e₀, he₀⟩ := h_e_const
  obtain ⟨subsubseq, hsubsubseq_mono, hsubsubseq_const⟩ :
      ∃ subsubseq : ℕ → ℕ, StrictMono subsubseq ∧
        ∀ r, e (subseq (subsubseq r)) = e₀ := by
    refine ⟨fun r => Nat.recOn r (Nat.find he₀.nonempty)
        (fun r ih => Nat.find (he₀.exists_gt ih)), ?_, ?_⟩
    · exact strictMono_nat_of_lt_succ fun r => (Nat.find_spec (he₀.exists_gt _)).2
    · intro r
      exact Nat.recOn r (Nat.find_spec he₀.nonempty)
        (fun r ih => (Nat.find_spec (he₀.exists_gt _)).1)
  have h_y_tendsto : ∀ j,
      Filter.Tendsto (fun r => Classical.choose (he (subseq (subsubseq r)) j))
        Filter.atTop (nhds x_star) := by
    intro j
    have h_dist : Filter.Tendsto
        (fun r => dist (x (subseq (subsubseq r)))
          (Classical.choose (he (subseq (subsubseq r)) j)))
        Filter.atTop (nhds 0) := by
      refine squeeze_zero
        (f := fun r => dist (x (subseq (subsubseq r)))
          (Classical.choose (he (subseq (subsubseq r)) j)))
        (g := fun r => 1 / (subseq (subsubseq r) + 1 : ℝ))
        (fun _ => dist_nonneg) ?_ ?_
      · intro r
        exact (Classical.choose_spec (he (subseq (subsubseq r)) j)).2.le
      · exact tendsto_one_div_add_atTop_nhds_zero_nat.comp
          (hsubseq_mono.tendsto_atTop.comp hsubsubseq_mono.tendsto_atTop)
    have h_diff_tendsto : Filter.Tendsto
        (fun r => x (subseq (subsubseq r)) -
          Classical.choose (he (subseq (subsubseq r)) j))
        Filter.atTop (nhds 0) := by
      exact tendsto_zero_iff_norm_tendsto_zero.mpr (by simpa [dist_eq_norm] using h_dist)
    simpa using h_diff_tendsto.neg.add
      (hsubseq_tendsto.comp hsubsubseq_mono.tendsto_atTop)
  refine ⟨x_star, hx_star, e₀, ?_⟩
  intro j
  have h_y_in_pref : ∀ r,
      Classical.choose (he (subseq (subsubseq r)) j) ∈
        stromquistWeakPreferenceSet n μ (e₀.symm j) j := by
    intro r
    simpa only [hsubsubseq_const r] using
      (Classical.choose_spec (he (subseq (subsubseq r)) j)).1
  exact IsClosed.mem_of_tendsto
    (stromquistWeakPreferenceSet_closed n μ (e₀.symm j) j)
    (h_y_tendsto j)
    (Filter.Eventually.of_forall h_y_in_pref)

/-- Positive-measure Stromquist case: if every agent gives positive value to
`[0,1)`, then there is a common weak-preference point and a bijection from
pieces to agents. -/
theorem stromquist_preferenceEquiv_exists_of_positive
    (hn : 0 < n)
    (hpos : ∀ j : Fin n, 0 < μ j (Set.Ico 0 1)) :
    ∃ (x : Fin n → ℝ) (_ : x ∈ stdSimplex ℝ (Fin n)) (e : Fin n ≃ Fin n),
      ∀ j : Fin n, x ∈ stromquistWeakPreferenceSet n μ (e.symm j) j := by
  obtain ⟨α, hα⟩ := Math.Fin.irrationalShifts_exist n
  obtain ⟨M₀, hM₀_pos, hface⟩ :=
    stromquistApproxPreferenceUnion_eventually_avoids_faces n μ hn α hpos
  refine stromquist_preferenceEquiv_exists_of_approx n μ ?_
  intro ε hε
  let M : ℕ := ⌊(n : ℝ) / ε⌋₊ + M₀ + 1
  have hM_ge : M₀ ≤ M := by
    omega
  have hM_pos : 0 < M := lt_of_lt_of_le hM₀_pos hM_ge
  have h_n_div_M : (n : ℝ) / (M : ℝ) < ε := by
    have hM_real : ((⌊(n : ℝ) / ε⌋₊ + 1 : ℕ) : ℝ) ≤ M := by
      simp [M]
    have hfloor : (n : ℝ) / ε < ((⌊(n : ℝ) / ε⌋₊ + 1 : ℕ) : ℝ) := by
      simpa [Nat.cast_add, Nat.cast_one] using Nat.lt_floor_add_one ((n : ℝ) / ε)
    have hM_real' : (n : ℝ) / ε < (M : ℝ) := lt_of_lt_of_le hfloor hM_real
    have hM_real_pos : (0 : ℝ) < M := by exact_mod_cast hM_pos
    rw [div_lt_iff₀ hM_real_pos]
    calc
      (n : ℝ) = ((n : ℝ) / ε) * ε := by
        rw [div_mul_cancel₀ _ hε.ne']
      _ < (M : ℝ) * ε := mul_lt_mul_of_pos_right hM_real' hε
      _ = ε * (M : ℝ) := by ring
  obtain ⟨x, hx, e, hwit⟩ :=
    stromquistApproxPreferenceWitnesses n μ hn α hα M hM_pos (hface M hM_ge)
  refine ⟨x, hx, e, fun j => ?_⟩
  obtain ⟨y, hyPref, _hyS, hydist⟩ := hwit j
  exact ⟨y, hyPref, lt_of_le_of_lt hydist h_n_div_M⟩

/-- Stromquist's real-line construction for positive finite non-atomic measures
supported on `[0,1)`. -/
theorem stromquist_envyFree_exists_of_positive
    (hn : 0 < n)
    (hpos : ∀ j : Fin n, 0 < μ j (Set.Ico 0 1))
    (hsupp : ∀ j : Fin n, μ j = (μ j).restrict (Set.Ico 0 1)) :
    ∃ A : Allocation (Fin n) ℝ,
      IsAllocation A ∧ IsEnvyFree (MeasureValuation μ) A := by
  obtain ⟨x, hx, e, hpref⟩ := stromquist_preferenceEquiv_exists_of_positive n μ hn hpos
  exact stromquist_envyFree_exists_of_preferenceEquiv n μ hn x hx e hpref hsupp

/-- Stromquist's real-line construction for finite non-atomic measures
supported on `[0,1)`. Agents assigning zero total value to the cake are handled
by replacing their measures with a positive nonatomic reference measure while
constructing the preference point. -/
theorem stromquist_envyFree_exists
    (hn : 0 < n)
    (hsupp : ∀ j : Fin n, μ j = (μ j).restrict (Set.Ico 0 1)) :
    ∃ A : Allocation (Fin n) ℝ,
      IsAllocation A ∧ IsEnvyFree (MeasureValuation μ) A := by
  let μpos : Fin n → Measure ℝ :=
    fun j => if 0 < μ j (Set.Ico 0 1) then μ j else volume.restrict (Set.Ico 0 1)
  haveI hfin_pos : ∀ j : Fin n, IsFiniteMeasure (μpos j) := fun j => by
    by_cases hj : 0 < μ j (Set.Ico 0 1)
    · simpa [μpos, hj] using (inferInstance : IsFiniteMeasure (μ j))
    · simpa [μpos, hj] using
        (inferInstance : IsFiniteMeasure (volume.restrict (Set.Ico (0 : ℝ) 1)))
  haveI hnoatoms_pos : ∀ j : Fin n, NullSingletonClass (μpos j) := fun j => by
    by_cases hj : 0 < μ j (Set.Ico 0 1)
    · simpa [μpos, hj] using (inferInstance : NullSingletonClass (μ j))
    · simpa [μpos, hj] using
        (inferInstance : NullSingletonClass (volume.restrict (Set.Ico (0 : ℝ) 1)))
  have hpos_pos : ∀ j : Fin n, 0 < μpos j (Set.Ico 0 1) := by
    intro j
    by_cases hj : 0 < μ j (Set.Ico 0 1)
    · simp [μpos, hj]
    · simp [μpos, hj]
  obtain ⟨x, hx, e, hpref_pos⟩ :=
    stromquist_preferenceEquiv_exists_of_positive n μpos hn hpos_pos
  obtain ⟨_, _, hcover01⟩ := stromquistPiece_partition n x hx
  have hpiece_sub : ∀ k : Fin n, stromquistPiece n x k ⊆ Set.Ico 0 1 :=
    fun k => hcover01 ▸ Set.subset_iUnion (stromquistPiece n x) k
  have hpref : ∀ j : Fin n, x ∈ stromquistWeakPreferenceSet n μ (e.symm j) j := by
    intro j
    by_cases hj : 0 < μ j (Set.Ico 0 1)
    · intro k
      have h := hpref_pos j k
      simpa [μpos, hj, stromquistValue] using h
    · have hj_zero : μ j (Set.Ico 0 1) = 0 :=
        le_antisymm (le_of_not_gt hj) zero_le
      intro k
      have hk_zero : μ j (stromquistPiece n x k) = 0 :=
        measure_mono_null (hpiece_sub k) hj_zero
      have hown_zero : μ j (stromquistPiece n x (e.symm j)) = 0 :=
        measure_mono_null (hpiece_sub (e.symm j)) hj_zero
      simp [stromquistValue, hk_zero, hown_zero]
  exact stromquist_envyFree_exists_of_preferenceEquiv n μ hn x hx e hpref hsupp

