/-- For a fixed agent, approximate unique-preference sets for distinct pieces
are disjoint. -/
theorem disjoint_stromquistApproxUniquePreferenceSet
    (M : ℕ) (α : Fin n → ℝ) (j i i' : Fin n) (hii' : i ≠ i') :
    Disjoint (stromquistApproxUniquePreferenceSet n μ M α i j)
      (stromquistApproxUniquePreferenceSet n μ M α i' j) := by
  classical
  simp only [Set.disjoint_left, stromquistApproxUniquePreferenceSet]
  intro x hx hx'
  rcases Set.mem_iUnion.mp hx with ⟨p, hp⟩
  rcases Set.mem_iUnion.mp hx' with ⟨q, hq⟩
  by_cases hpOwner : stromquistCellOwner n μ M α j p = some i
  · by_cases hqOwner : stromquistCellOwner n μ M α j q = some i'
    · have hxp : x ∈ stromquistShiftedCell n M α j p := by
        rw [if_pos hpOwner] at hp
        exact hp
      have hxq : x ∈ stromquistShiftedCell n M α j q := by
        rw [if_pos hqOwner] at hq
        exact hq
      have hpEq : p = q := by
        funext k
        rcases hxp k with ⟨hpk0, hpk1⟩
        rcases hxq k with ⟨hqk0, hqk1⟩
        let t : ℝ := (M : ℝ) * (x ⟨k.1, by omega⟩ - α j)
        have hpFloor : Int.floor t = p k := by
          rw [Int.floor_eq_iff]
          exact ⟨le_of_lt hpk0, hpk1⟩
        have hqFloor : Int.floor t = q k := by
          rw [Int.floor_eq_iff]
          exact ⟨le_of_lt hqk0, hqk1⟩
        exact hpFloor.symm.trans hqFloor
      have hOwnerq : stromquistCellOwner n μ M α j p = some i' := by
        simpa [hpEq] using hqOwner
      have : some i = some i' := hpOwner.symm.trans hOwnerq
      exact hii' (Option.some.inj this)
    · have : x ∈ (∅ : Set (Fin n → ℝ)) := by
        rw [if_neg hqOwner] at hq
        exact hq
      exact this
  · have : x ∈ (∅ : Set (Fin n → ℝ)) := by
      rw [if_neg hpOwner] at hp
      exact hp
    exact this

