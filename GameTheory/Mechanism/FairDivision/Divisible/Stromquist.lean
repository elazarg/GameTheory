import GameTheory.Mechanism.FairDivision.Divisible.Basic
import Math.Fin
import Math.FixedPoint.KKM
import Math.MeasureTheory.UnitInterval
import Mathlib.Analysis.Convex.StdSimplex
import Mathlib.MeasureTheory.Constructions.UnitInterval
import Mathlib.MeasureTheory.Measure.Lebesgue.Basic
import Mathlib.Tactic

/-!
# Stromquist's Envy-Free Division

The interval-cut geometry, KKM step, shifted-grid approximation, and compactness
argument used in Stromquist's envy-free division proof for finite nonatomic
measure instances.
-/

open MeasureTheory Set Topology
open scoped unitInterval

namespace GameTheory
namespace SocialChoice
namespace FairDivision
namespace Divisible

variable (n : ℕ) (μ : Fin n → Measure ℝ)
variable [∀ i, IsFiniteMeasure (μ i)] [∀ i, NullSingletonClass (μ i)]

/-- The `i`-th interval piece generated by simplex coordinates `x`.  The piece
runs from the cumulative mass before `i` to the cumulative mass through `i`. -/
noncomputable def stromquistPiece (x : Fin n → ℝ) (i : Fin n) : Set ℝ :=
  Set.Ico (∑ j ∈ Finset.univ.filter (· < i), x j)
    (∑ j ∈ Finset.univ.filter (· ≤ i), x j)

/-- The pieces generated by a simplex point form a measurable partition of
`Ico 0 1`. -/
theorem stromquistPiece_partition (x : Fin n → ℝ) (hx : x ∈ stdSimplex ℝ (Fin n)) :
    (∀ i, MeasurableSet (stromquistPiece n x i)) ∧
    (∀ i j : Fin n, i ≠ j → Disjoint (stromquistPiece n x i) (stromquistPiece n x j)) ∧
    (⋃ i, stromquistPiece n x i = Set.Ico 0 1) := by
  have hnn : ∀ i, 0 ≤ x i := hx.1
  have hsum : ∑ i, x i = 1 := hx.2
  have hn' : 0 < n := by
    rcases Nat.eq_zero_or_pos n with rfl | h
    · simp at hsum
    · exact h
  let L : Fin n → ℝ := fun i => ∑ j ∈ Finset.univ.filter (· < i), x j
  let U : Fin n → ℝ := fun i => ∑ j ∈ Finset.univ.filter (· ≤ i), x j
  have hdef : ∀ i, stromquistPiece n x i = Set.Ico (L i) (U i) := fun _ => rfl
  have hUlast : U ⟨n - 1, by omega⟩ = 1 := by
    simp only [U]
    have heq : Finset.univ.filter (· ≤ (⟨n - 1, by omega⟩ : Fin n)) = Finset.univ := by
      apply Finset.filter_true_of_mem
      intro j _
      rw [Fin.le_iff_val_le_val]
      change j.val ≤ n - 1
      have := j.isLt
      omega
    rw [heq]
    exact hsum
  have hU_le_L : ∀ i j : Fin n, i < j → U i ≤ L j := fun i j hij =>
    Finset.sum_le_sum_of_subset_of_nonneg
      (fun k => by
        simp only [Finset.mem_filter, Finset.mem_univ, true_and]
        exact fun hk => hk.trans_lt hij)
      (fun k _ _ => hnn k)
  have hL_nonneg : ∀ i, 0 ≤ L i := fun i => Finset.sum_nonneg fun j _ => hnn j
  have hU_le_one : ∀ i, U i ≤ 1 := fun i => by
    calc
      U i ≤ ∑ j : Fin n, x j :=
        Finset.sum_le_sum_of_subset_of_nonneg (by simp) (fun k _ _ => hnn k)
      _ = 1 := hsum
  refine ⟨fun i => hdef i ▸ measurableSet_Ico, ?_, ?_⟩
  · intro i j hij
    rw [hdef i, hdef j, Set.Ico_disjoint_Ico]
    rcases lt_or_gt_of_ne hij with h | h
    · exact (min_le_left _ _).trans ((hU_le_L i j h).trans (le_max_right _ _))
    · exact (min_le_right _ _).trans ((hU_le_L j i h).trans (le_max_left _ _))
  · simp_rw [hdef]
    ext t
    simp only [Set.mem_iUnion, Set.mem_Ico]
    constructor
    · rintro ⟨i, hlo, hhi⟩
      exact ⟨(hL_nonneg i).trans hlo, hhi.trans_le (hU_le_one i)⟩
    · intro ⟨ht0, ht1⟩
      have hS_ne : (Finset.univ.filter (fun i : Fin n => t < U i)).Nonempty :=
        ⟨⟨n - 1, by omega⟩, Finset.mem_filter.mpr ⟨Finset.mem_univ _, hUlast ▸ ht1⟩⟩
      set i₀ := (Finset.univ.filter (fun i : Fin n => t < U i)).min' hS_ne
      refine ⟨i₀, ?_, (Finset.mem_filter.mp (Finset.min'_mem _ hS_ne)).2⟩
      rcases Nat.eq_zero_or_pos i₀.val with h0 | hpos
      · have hempty : Finset.univ.filter (fun j : Fin n => j < i₀) = ∅ := by
          rw [Finset.filter_eq_empty_iff]
          intro j _
          simp only [not_lt, Fin.le_iff_val_le_val, h0]
          exact Nat.zero_le _
        simp [L, hempty, ht0]
      · have hpred_lt : i₀.val - 1 < n := by omega
        set pred : Fin n := ⟨i₀.val - 1, hpred_lt⟩
        have hconsec : U pred = L i₀ := by
          simp only [U, L, pred]
          congr 1
          ext j
          simp only [Finset.mem_filter, Finset.mem_univ, true_and,
            Fin.le_iff_val_le_val, Fin.lt_def]
          omega
        have hpred_not_mem : pred ∉ Finset.univ.filter (fun i : Fin n => t < U i) := by
          intro hmem
          have hpred_lt' : pred < i₀ := Fin.lt_def.mpr (by simp [pred]; omega)
          exact absurd (Finset.min'_le _ _ hmem) (not_le.mpr hpred_lt')
        simp only [Finset.mem_filter, Finset.mem_univ, true_and, not_lt] at hpred_not_mem
        linarith [hconsec]

/-- Piece `i` is empty exactly when coordinate `i` is zero. -/
theorem stromquistPiece_empty_iff (x : Fin n → ℝ) (hx : x ∈ stdSimplex ℝ (Fin n))
    (i : Fin n) :
    stromquistPiece n x i = ∅ ↔ x i = 0 := by
  simp only [stromquistPiece, Set.Ico_eq_empty_iff, not_lt]
  have key : ∑ j ∈ Finset.univ.filter (· ≤ i), x j =
      ∑ j ∈ Finset.univ.filter (· < i), x j + x i := by
    have hsplit : Finset.univ.filter (fun j : Fin n => j ≤ i) =
        (Finset.univ.filter (fun j : Fin n => j < i)) ∪ {i} := by
      ext j
      simp only [Finset.mem_filter, Finset.mem_univ, true_and, Finset.mem_union,
        Finset.mem_singleton]
      exact le_iff_lt_or_eq
    have hdisj : Disjoint (Finset.univ.filter (fun j : Fin n => j < i)) {i} := by
      simp only [Finset.disjoint_singleton_right, Finset.mem_filter, Finset.mem_univ,
        true_and]
      exact lt_irrefl i
    rw [hsplit, Finset.sum_union hdisj, Finset.sum_singleton]
  constructor
  · intro h
    linarith [hx.1 i]
  · intro h
    rw [key]
    linarith

/-- Agent `j`'s real-valued measure of piece `i` at division `x`. -/
noncomputable def stromquistValue (x : Fin n → ℝ) (j i : Fin n) : ℝ :=
  (μ j (stromquistPiece n x i)).toReal

/-- For fixed agent and piece, `stromquistValue` is continuous in the cut
coordinates. -/
theorem stromquistValue_continuous (j i : Fin n) :
    Continuous (fun x : Fin n → ℝ => stromquistValue n μ x j i) := by
  have hcdf : Continuous (fun t : ℝ => (μ j (Set.Iic t)).toReal) :=
    Math.MeasureTheory.cdfRealContinuous (μ j)
  have hl_cont : Continuous (fun x : Fin n → ℝ =>
      ∑ k ∈ Finset.univ.filter (· < i), x k) :=
    continuous_finsetSum _ fun k _ => continuous_apply k
  have hr_cont : Continuous (fun x : Fin n → ℝ =>
      ∑ k ∈ Finset.univ.filter (· ≤ i), x k) :=
    continuous_finsetSum _ fun k _ => continuous_apply k
  have hval_eq : ∀ x : Fin n → ℝ, stromquistValue n μ x j i =
      max ((μ j (Set.Iic (∑ k ∈ Finset.univ.filter (· ≤ i), x k))).toReal -
           (μ j (Set.Iic (∑ k ∈ Finset.univ.filter (· < i), x k))).toReal) 0 := fun x => by
    simp only [stromquistValue, stromquistPiece]
    exact Math.MeasureTheory.measure_Ico_toReal (μ j) _ _
  simp_rw [hval_eq]
  exact (hcdf.comp hr_cont |>.sub (hcdf.comp hl_cont)).max continuous_const

/-- Points where piece `i` is a weak maximizer for agent `j`. -/
def stromquistWeakPreferenceSet (i j : Fin n) : Set (Fin n → ℝ) :=
  {x : Fin n → ℝ | ∀ k : Fin n, stromquistValue n μ x j k ≤ stromquistValue n μ x j i}

/-- Weak preference sets are closed. -/
theorem stromquistWeakPreferenceSet_closed (i j : Fin n) :
    IsClosed (stromquistWeakPreferenceSet n μ i j) := by
  simp only [stromquistWeakPreferenceSet, Set.setOf_forall]
  exact isClosed_iInter fun k =>
    isClosed_le (stromquistValue_continuous n μ j k) (stromquistValue_continuous n μ j i)

omit [∀ i, IsFiniteMeasure (μ i)] [∀ i, NullSingletonClass (μ i)] in
/-- For each agent, weak preference sets over pieces cover the simplex. -/
theorem stromquistWeakPreferenceSet_covers (j : Fin n) :
    stdSimplex ℝ (Fin n) ⊆ ⋃ i, stromquistWeakPreferenceSet n μ i j := by
  intro x _
  have hne : (Finset.univ : Finset (Fin n)).Nonempty := ⟨j, Finset.mem_univ j⟩
  obtain ⟨i, _, hi⟩ :=
    Finset.exists_max_image Finset.univ (fun i => stromquistValue n μ x j i) hne
  exact Set.mem_iUnion.mpr ⟨i, fun k => hi k (Finset.mem_univ k)⟩

omit [∀ i, NullSingletonClass (μ i)] in
/-- If agent `j` has positive value for `[0,1)`, the weak preference set for
piece `i` misses the face where piece `i` has zero length. -/
theorem stromquistWeakPreferenceSet_avoids_face (i j : Fin n)
    (hpos : 0 < μ j (Set.Ico 0 1)) :
    stromquistWeakPreferenceSet n μ i j ∩ Math.FixedPoint.simplexFaceOpp i = ∅ := by
  rw [Set.eq_empty_iff_forall_notMem]
  intro x ⟨hA, hface⟩
  simp only [Math.FixedPoint.simplexFaceOpp, Set.mem_inter_iff, Set.mem_setOf_eq] at hface
  obtain ⟨hxi, hx_simp⟩ := hface
  have hpi : stromquistPiece n x i = ∅ :=
    (stromquistPiece_empty_iff n x hx_simp i).mpr hxi
  have hvi : stromquistValue n μ x j i = 0 := by
    simp [stromquistValue, hpi]
  have hv_zero : ∀ k, μ j (stromquistPiece n x k) = 0 := by
    intro k
    have hle : stromquistValue n μ x j k ≤ 0 := hvi ▸ hA k
    have hnn : 0 ≤ stromquistValue n μ x j k := ENNReal.toReal_nonneg
    have heq : stromquistValue n μ x j k = 0 := le_antisymm hle hnn
    simp only [stromquistValue, ENNReal.toReal_eq_zero_iff] at heq
    exact heq.resolve_right (measure_ne_top _ _)
  obtain ⟨hmeas, hdisj, hcover⟩ := stromquistPiece_partition n x hx_simp
  have hmeasure_zero : μ j (Set.Ico 0 1) = 0 := by
    rw [← hcover, measure_iUnion (fun ⦃a b⦄ hab => hdisj a b hab) hmeas, tsum_fintype]
    exact Finset.sum_eq_zero fun k _ => hv_zero k
  exact absurd hmeasure_zero (ne_of_gt hpos)

/-- Points where piece `i` is the unique maximizer for agent `j`. -/
def stromquistUniquePreferenceSet (i j : Fin n) : Set (Fin n → ℝ) :=
  stromquistWeakPreferenceSet n μ i j \
    ⋃ k ∈ Finset.univ.filter (· ≠ i), stromquistWeakPreferenceSet n μ k j

/-- Unique preference sets are open. -/
theorem stromquistUniquePreferenceSet_open (i j : Fin n) :
    IsOpen (stromquistUniquePreferenceSet n μ i j) := by
  have hkey : stromquistUniquePreferenceSet n μ i j =
      ⋂ k ∈ Finset.univ.filter (· ≠ i),
        {x : Fin n → ℝ | stromquistValue n μ x j k < stromquistValue n μ x j i} := by
    ext x
    simp only [stromquistUniquePreferenceSet, stromquistWeakPreferenceSet, Set.mem_sdiff,
      Set.mem_setOf_eq, Set.mem_iUnion, Finset.mem_filter, Finset.mem_univ, true_and,
      Set.mem_iInter, not_exists]
    constructor
    · intro ⟨hmax, hno⟩ k hki
      exact lt_of_le_of_ne (hmax k) (fun h => hno k hki (fun m => h ▸ hmax m))
    · intro hlt
      refine ⟨fun k => ?_, fun k hki hAk => absurd (hAk i) (not_le.mpr (hlt k hki))⟩
      rcases eq_or_ne k i with rfl | hki
      · exact le_refl _
      · exact le_of_lt (hlt k hki)
  rw [hkey]
  apply isOpen_biInter_finset
  intro k _
  exact isOpen_lt (stromquistValue_continuous n μ j k) (stromquistValue_continuous n μ j i)

omit [∀ i, IsFiniteMeasure (μ i)] [∀ i, NullSingletonClass (μ i)] in
/-- For a fixed agent, two distinct pieces cannot both be uniquely best. -/
theorem disjoint_stromquistUniquePreferenceSet (j i i' : Fin n) (hii' : i ≠ i') :
    Disjoint (stromquistUniquePreferenceSet n μ i j) (stromquistUniquePreferenceSet n μ i' j) := by
  simp only [Set.disjoint_left, stromquistUniquePreferenceSet]
  intro x ⟨_, hnotA⟩ ⟨hAi', _⟩
  apply hnotA
  rw [Set.mem_iUnion₂]
  exact ⟨i', Finset.mem_filter.mpr ⟨Finset.mem_univ _, hii'.symm⟩, hAi'⟩

/-- Divisions where some agent uniquely prefers piece `i`. -/
def stromquistUniquePreferenceUnion (i : Fin n) : Set (Fin n → ℝ) :=
  ⋃ j, stromquistUniquePreferenceSet n μ i j

/-- The union of unique preferences for a fixed piece is open. -/
theorem stromquistUniquePreferenceUnion_open (i : Fin n) :
    IsOpen (stromquistUniquePreferenceUnion n μ i) := by
  exact isOpen_iUnion (stromquistUniquePreferenceSet_open n μ i ·)

omit [∀ i, NullSingletonClass (μ i)] in
/-- The union of unique preferences for piece `i` misses the face where that
piece has zero length. -/
theorem stromquistUniquePreferenceUnion_avoids_face (i : Fin n)
    (hpos : ∀ j : Fin n, 0 < μ j (Set.Ico 0 1)) :
    stromquistUniquePreferenceUnion n μ i ∩ Math.FixedPoint.simplexFaceOpp i = ∅ := by
  rw [Set.eq_empty_iff_forall_notMem]
  intro x ⟨hU, hface⟩
  obtain ⟨j, hj⟩ := Set.mem_iUnion.mp hU
  have hB_sub_A :
      stromquistUniquePreferenceSet n μ i j ⊆ stromquistWeakPreferenceSet n μ i j :=
    Set.sdiff_subset
  have hA_mem : x ∈ stromquistWeakPreferenceSet n μ i j := hB_sub_A hj
  have := Set.eq_empty_iff_forall_notMem.mp
    (stromquistWeakPreferenceSet_avoids_face n μ i j (hpos j)) x
  exact this ⟨hA_mem, hface⟩

omit [∀ i, IsFiniteMeasure (μ i)] [∀ i, NullSingletonClass (μ i)] in
private theorem stromquist_fair_assignment (x : Fin n → ℝ)
    (hU : ∀ i, x ∈ stromquistUniquePreferenceUnion n μ i) :
    ∃ assign : Fin n → Fin n, Function.Injective assign ∧
      ∀ i, x ∈ stromquistWeakPreferenceSet n μ i (assign i) ∧
           ∀ k ≠ i, stromquistValue n μ x (assign i) k <
             stromquistValue n μ x (assign i) i := by
  have hchoice : ∀ i, ∃ j, x ∈ stromquistUniquePreferenceSet n μ i j :=
    fun i => Set.mem_iUnion.mp (hU i)
  let assign : Fin n → Fin n := fun i => (hchoice i).choose
  have hassign_mem : ∀ i, x ∈ stromquistUniquePreferenceSet n μ i (assign i) :=
    fun i => (hchoice i).choose_spec
  refine ⟨assign, ?_, ?_⟩
  · intro i i' heq
    by_contra hii'
    have h1 : x ∈ stromquistUniquePreferenceSet n μ i (assign i') := by
      simpa [heq] using hassign_mem i
    have h2 : x ∈ stromquistUniquePreferenceSet n μ i' (assign i') :=
      hassign_mem i'
    exact Set.disjoint_left.mp
      (disjoint_stromquistUniquePreferenceSet n μ _ i i' hii') h1 h2
  · intro i
    have hB : x ∈ stromquistUniquePreferenceSet n μ i (assign i) :=
      hassign_mem i
    have hA : x ∈ stromquistWeakPreferenceSet n μ i (assign i) :=
      Set.sdiff_subset hB
    constructor
    · exact hA
    · intro k hki
      have hnotAk : x ∉ stromquistWeakPreferenceSet n μ k ((hchoice i).choose) := by
        intro hc
        exact hB.2 (Set.mem_biUnion
          (Finset.mem_filter.mpr ⟨Finset.mem_univ k, hki⟩) hc)
      exact lt_of_le_of_ne (hA k) (fun h => hnotAk (fun m => h ▸ hA m))

omit [∀ i, NullSingletonClass (μ i)] in
/-- A common weak-preference point, together with a bijection assigning pieces
to agents, induces an envy-free allocation. -/
theorem stromquist_envyFree_exists_of_preferenceEquiv
    (hn : 0 < n)
    (x : Fin n → ℝ) (hx : x ∈ stdSimplex ℝ (Fin n))
    (e : Fin n ≃ Fin n)
    (hpref : ∀ j : Fin n, x ∈ stromquistWeakPreferenceSet n μ (e.symm j) j)
    (hsupp : ∀ j : Fin n, μ j = (μ j).restrict (Set.Ico 0 1)) :
    ∃ A : Allocation (Fin n) ℝ,
      IsAllocation A ∧ IsEnvyFree (MeasureValuation μ) A := by
  obtain ⟨hmeas, hdisj, hcover01⟩ := stromquistPiece_partition n x hx
  have hpiece_sub : ∀ k, stromquistPiece n x k ⊆ Set.Ico 0 1 :=
    fun k => hcover01 ▸ Set.subset_iUnion (stromquistPiece n x) k
  have hext : ∀ i : Fin n, μ i (Set.Iio 0 ∪ Set.Ici 1) = 0 := fun i => by
    rw [hsupp i, Measure.restrict_apply (measurableSet_Iio.union measurableSet_Ici)]
    have h1 : (Set.Iio (0 : ℝ) ∪ Set.Ici 1) ∩ Set.Ico 0 1 = ∅ := by
      ext t
      simp only [Set.mem_inter_iff, Set.mem_union, Set.mem_Iio, Set.mem_Ici,
        Set.mem_Ico, Set.mem_empty_iff_false, iff_false, not_and]
      rintro (h | h) <;> intro h2 <;> linarith
    rw [h1]
    exact measure_empty
  have hext_disj : ∀ k, Disjoint (stromquistPiece n x k) (Set.Iio 0 ∪ Set.Ici 1) :=
    fun k => Set.disjoint_left.mpr fun t ht_p ht_e => by
      have := hpiece_sub k ht_p
      simp only [Set.mem_Ico] at this
      simp only [Set.mem_union, Set.mem_Iio, Set.mem_Ici] at ht_e
      rcases ht_e with h | h <;> linarith [this.1, this.2]
  let z : Fin n := ⟨0, hn⟩
  refine ⟨fun agent =>
    if agent = z then stromquistPiece n x (e.symm agent) ∪ (Set.Iio 0 ∪ Set.Ici 1)
    else stromquistPiece n x (e.symm agent), ⟨?_, ?_, ?_⟩, ?_⟩
  · intro agent
    simp only [z]
    split_ifs
    · exact (hmeas _).union (measurableSet_Iio.union measurableSet_Ici)
    · exact hmeas _
  · intro i j hij
    have heij : e.symm i ≠ e.symm j := fun h => hij (e.symm.injective h)
    simp only [z]
    split_ifs with hi0 hj0 hj0
    · exact absurd (hi0.trans hj0.symm) hij
    · rw [Set.disjoint_union_left]
      exact ⟨hdisj _ _ heij, (hext_disj (e.symm j)).symm⟩
    · rw [Set.disjoint_union_right]
      exact ⟨hdisj _ _ heij, hext_disj (e.symm i)⟩
    · exact hdisj _ _ heij
  · ext t
    simp only [Set.mem_iUnion, Set.mem_univ, iff_true]
    by_cases ht01 : t ∈ Set.Ico 0 1
    · rw [← hcover01] at ht01
      obtain ⟨k, hk⟩ := Set.mem_iUnion.mp ht01
      refine ⟨e k, ?_⟩
      split_ifs
      · rw [e.symm_apply_apply]
        exact Set.mem_union_left _ hk
      · rw [e.symm_apply_apply]
        exact hk
    · refine ⟨z, ?_⟩
      refine Set.mem_union_right _ ?_
      simp only [Set.mem_Ico, not_and_or, not_lt] at ht01
      simp only [Set.mem_union, Set.mem_Iio, Set.mem_Ici]
      rcases ht01 with h | h
      · exact Or.inl (not_le.mp h)
      · exact Or.inr h
  · have hA_measure : ∀ (i j : Fin n),
        μ i (if j = z then stromquistPiece n x (e.symm j) ∪ (Set.Iio 0 ∪ Set.Ici 1)
              else stromquistPiece n x (e.symm j)) =
          μ i (stromquistPiece n x (e.symm j)) := by
      intro i j
      split_ifs
      · rw [measure_union (hext_disj _) (measurableSet_Iio.union measurableSet_Ici),
          hext i, add_zero]
      · rfl
    intro i j
    simp only [z] at hA_measure ⊢
    simp only [MeasureValuation]
    rw [hA_measure i j, hA_measure i i]
    have hle := hpref i (e.symm j)
    simp only [stromquistValue] at hle
    exact (ENNReal.toReal_le_toReal (measure_ne_top _ _) (measure_ne_top _ _)).mp hle

/-- Usual case of Stromquist's construction: if every simplex point lies in
some open set of uniquely preferred pieces, then there is an envy-free
allocation. -/
theorem stromquist_usualCase_envyFree_exists
    (hn : 0 < n)
    (hcover : stdSimplex ℝ (Fin n) ⊆ ⋃ i, stromquistUniquePreferenceUnion n μ i)
    (hpos : ∀ j : Fin n, 0 < μ j (Set.Ico 0 1))
    (hsupp : ∀ j : Fin n, μ j = (μ j).restrict (Set.Ico 0 1)) :
    ∃ A : Allocation (Fin n) ℝ,
      IsAllocation A ∧ IsEnvyFree (MeasureValuation μ) A := by
  obtain ⟨x, hx_simp, hx_U⟩ := Math.FixedPoint.kkm_open_cover hn
    (stromquistUniquePreferenceUnion n μ)
    (stromquistUniquePreferenceUnion_open n μ)
    (fun i => by
      intro x hx_face hx_U
      have h := Set.mem_inter hx_U hx_face
      rw [stromquistUniquePreferenceUnion_avoids_face n μ i hpos] at h
      simp at h)
    hcover
  obtain ⟨assign, hinj, hassign⟩ := stromquist_fair_assignment n μ x hx_U
  have hbij : Function.Bijective assign := Finite.injective_iff_bijective.mp hinj
  let e : Fin n ≃ Fin n := Equiv.ofBijective assign hbij
  exact stromquist_envyFree_exists_of_preferenceEquiv n μ hn x hx_simp e (fun i => by
      have h := (hassign (e.symm i)).1
      have heq : assign (e.symm i) = i := e.apply_symm_apply i
      rwa [heq] at h) hsupp

/-- The open shifted cell determined by integer coordinates `p` for agent `j`.
The first `n - 1` coordinates are shifted by `α j` and meshed at scale `M`. -/
def stromquistShiftedCell (M : ℕ) (α : Fin n → ℝ) (j : Fin n)
    (p : Fin (n - 1) → ℤ) : Set (Fin n → ℝ) :=
  {x | ∀ k : Fin (n - 1),
    (p k : ℝ) < (M : ℝ) * (x ⟨k.1, by omega⟩ - α j) ∧
      (M : ℝ) * (x ⟨k.1, by omega⟩ - α j) < (p k : ℝ) + 1}

/-- A shifted cell hits piece `i` for agent `j` when it contains a simplex point
where `i` is weakly best for that agent. -/
def stromquistCellHits (M : ℕ) (α : Fin n → ℝ) (j i : Fin n)
    (p : Fin (n - 1) → ℤ) : Prop :=
  ((stromquistShiftedCell n M α j p) ∩ stdSimplex ℝ (Fin n) ∩
    stromquistWeakPreferenceSet n μ i j).Nonempty

/-- The owner of a shifted cell is the least piece whose weak-preference set
meets that cell, if there is one. -/
noncomputable def stromquistCellOwner (M : ℕ) (α : Fin n → ℝ) (j : Fin n)
    (p : Fin (n - 1) → ℤ) : Option (Fin n) := by
  classical
  exact if h : ∃ i : Fin n, stromquistCellHits n μ M α j i p then
    some <| (Finset.univ.filter fun i => stromquistCellHits n μ M α j i p).min'
      (by
        rcases h with ⟨i, hi⟩
        exact ⟨i, Finset.mem_filter.mpr ⟨Finset.mem_univ i, hi⟩⟩)
  else
    none

/-- Approximate unique-preference set obtained by assigning shifted cells to
their owners. -/
noncomputable def stromquistApproxUniquePreferenceSet
    (M : ℕ) (α : Fin n → ℝ) (i j : Fin n) : Set (Fin n → ℝ) :=
  ⋃ p : Fin (n - 1) → ℤ,
    if stromquistCellOwner n μ M α j p = some i then
      stromquistShiftedCell n M α j p
    else
      ∅

/-- Approximate preference union for piece `i`. -/
noncomputable def stromquistApproxPreferenceUnion
    (M : ℕ) (α : Fin n → ℝ) (i : Fin n) : Set (Fin n → ℝ) :=
  ⋃ j : Fin n, stromquistApproxUniquePreferenceSet n μ M α i j

/-- Shifted cells are open in the ambient function space. -/
theorem stromquistShiftedCell_open (M : ℕ) (α : Fin n → ℝ) (j : Fin n)
    (p : Fin (n - 1) → ℤ) : IsOpen (stromquistShiftedCell n M α j p) := by
  classical
  change IsOpen ({x | ∀ k : Fin (n - 1),
    (p k : ℝ) < (M : ℝ) * (x ⟨k.1, by omega⟩ - α j) ∧
      (M : ℝ) * (x ⟨k.1, by omega⟩ - α j) < (p k : ℝ) + 1} : Set (Fin n → ℝ))
  rw [show ({x | ∀ k : Fin (n - 1),
      (p k : ℝ) < (M : ℝ) * (x ⟨k.1, by omega⟩ - α j) ∧
        (M : ℝ) * (x ⟨k.1, by omega⟩ - α j) < (p k : ℝ) + 1} : Set (Fin n → ℝ)) =
      ⋂ k ∈ (Finset.univ : Finset (Fin (n - 1))),
        {x | (p k : ℝ) < (M : ℝ) * (x ⟨k.1, by omega⟩ - α j) ∧
          (M : ℝ) * (x ⟨k.1, by omega⟩ - α j) < (p k : ℝ) + 1} by
    ext x
    simp]
  refine isOpen_biInter_finset fun k _ => ?_
  let g : (Fin n → ℝ) → ℝ := fun x => (M : ℝ) * (x ⟨k.1, by omega⟩ - α j)
  have hg : Continuous g := by
    fun_prop
  change IsOpen
    ({x : Fin n → ℝ | (p k : ℝ) < (M : ℝ) * (x ⟨k.1, by omega⟩ - α j)} ∩
      {x : Fin n → ℝ | (M : ℝ) * (x ⟨k.1, by omega⟩ - α j) < (p k : ℝ) + 1})
  simpa [g] using (isOpen_lt continuous_const hg).inter (isOpen_lt hg continuous_const)

omit [∀ i, IsFiniteMeasure (μ i)] [∀ i, NullSingletonClass (μ i)] in
/-- Approximate unique-preference sets are open. -/
theorem stromquistApproxUniquePreferenceSet_open
    (M : ℕ) (α : Fin n → ℝ) (i j : Fin n) :
    IsOpen (stromquistApproxUniquePreferenceSet n μ M α i j) := by
  classical
  refine isOpen_iUnion fun p => ?_
  by_cases h : stromquistCellOwner n μ M α j p = some i
  · simp [h, stromquistShiftedCell_open]
  · simp [h]

omit [∀ i, IsFiniteMeasure (μ i)] [∀ i, NullSingletonClass (μ i)] in
/-- Approximate preference unions are open. -/
theorem stromquistApproxPreferenceUnion_open
    (M : ℕ) (α : Fin n → ℝ) (i : Fin n) :
    IsOpen (stromquistApproxPreferenceUnion n μ M α i) := by
  exact isOpen_iUnion (stromquistApproxUniquePreferenceSet_open n μ M α i ·)

