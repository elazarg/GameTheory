private theorem stromquistCellOwner_eq_some_imp_hits
    (M : ℕ) (α : Fin n → ℝ) (j i : Fin n) (p : Fin (n - 1) → ℤ)
    (h : stromquistCellOwner n μ M α j p = some i) :
    stromquistCellHits n μ M α j i p := by
  classical
  unfold stromquistCellOwner at h
  split_ifs at h with hex
  · have hmem :
        (Finset.univ.filter fun i => stromquistCellHits n μ M α j i p).min'
          (by
            rcases hex with ⟨i0, hi0⟩
            exact ⟨i0, Finset.mem_filter.mpr ⟨Finset.mem_univ i0, hi0⟩⟩) ∈
        (Finset.univ.filter fun i => stromquistCellHits n μ M α j i p) :=
      Finset.min'_mem _ _
    have hhit :
        stromquistCellHits n μ M α j
          ((Finset.univ.filter fun i => stromquistCellHits n μ M α j i p).min'
            (by
              rcases hex with ⟨i0, hi0⟩
              exact ⟨i0, Finset.mem_filter.mpr ⟨Finset.mem_univ i0, hi0⟩⟩)) p :=
      (Finset.mem_filter.mp hmem).2
    injection h with hi
    simpa [hi] using hhit

/-- A simplex point lies on an agent-`j` shifted boundary hyperplane. -/
def stromquistOnShiftedBoundary (M : ℕ) (α : Fin n → ℝ) (j : Fin n)
    (x : Fin n → ℝ) : Prop :=
  ∃ k : Fin (n - 1), ∃ z : ℤ,
    (M : ℝ) * (x ⟨k.1, by omega⟩ - α j) = z

private theorem stromquist_mem_shiftedCell_of_not_onBoundary
    (α : Fin n → ℝ) (M : ℕ) (x : Fin n → ℝ) (j : Fin n)
    (hx : ¬ stromquistOnShiftedBoundary n M α j x) :
    let p : Fin (n - 1) → ℤ := fun k =>
      Int.floor ((M : ℝ) * (x ⟨k.1, by omega⟩ - α j))
    x ∈ stromquistShiftedCell n M α j p := by
  intro p k
  have hk : k.1 < n := Nat.lt_of_lt_of_le k.2 (Nat.sub_le n 1)
  constructor
  · have hle :
        ((Int.floor ((M : ℝ) * (x ⟨k.1, hk⟩ - α j))) : ℝ) ≤
          (M : ℝ) * (x ⟨k.1, hk⟩ - α j) :=
      Int.floor_le _
    have hne :
        ((Int.floor ((M : ℝ) * (x ⟨k.1, hk⟩ - α j))) : ℝ) ≠
          (M : ℝ) * (x ⟨k.1, hk⟩ - α j) := by
      intro hEq
      apply hx
      exact ⟨k, Int.floor ((M : ℝ) * (x ⟨k.1, hk⟩ - α j)), hEq.symm⟩
    exact lt_of_le_of_ne hle hne
  · simp [p]

omit [∀ i, IsFiniteMeasure (μ i)] [∀ i, NullSingletonClass (μ i)] in
/-- The shifted-cell unions cover the simplex when the agent shifts have
pairwise irrational differences. -/
theorem stromquistApproxPreferenceUnion_covers
    (hn : 0 < n)
    (α : Fin n → ℝ)
    (hα : Pairwise fun j k : Fin n => Irrational (α j - α k))
    (M : ℕ) (hM : 0 < M) :
    stdSimplex ℝ (Fin n) ⊆ ⋃ i, stromquistApproxPreferenceUnion n μ M α i := by
  intro x hx
  by_contra hxU
  have hxU' : ∀ i : Fin n, x ∉ stromquistApproxPreferenceUnion n μ M α i := by
    intro i hi
    exact hxU (Set.mem_iUnion.mpr ⟨i, hi⟩)
  have hxBoundary : ∀ j : Fin n, stromquistOnShiftedBoundary n M α j x := by
    intro j
    by_contra hj
    let p : Fin (n - 1) → ℤ := fun k =>
      Int.floor ((M : ℝ) * (x ⟨k.1, by omega⟩ - α j))
    have hxCell : x ∈ stromquistShiftedCell n M α j p :=
      stromquist_mem_shiftedCell_of_not_onBoundary n α M x j hj
    obtain ⟨i, hi⟩ := Set.mem_iUnion.mp (stromquistWeakPreferenceSet_covers n μ j hx)
    have hHit : stromquistCellHits n μ M α j i p := by
      refine ⟨x, ?_⟩
      exact ⟨⟨hxCell, hx⟩, hi⟩
    have hOwnerNeNone : stromquistCellOwner n μ M α j p ≠ none := by
      classical
      have hex : ∃ i : Fin n, stromquistCellHits n μ M α j i p := ⟨i, hHit⟩
      unfold stromquistCellOwner
      simp [hex]
    classical
    cases hOwner : stromquistCellOwner n μ M α j p with
    | none =>
        exact (hOwnerNeNone hOwner).elim
    | some i0 =>
        have hxB : x ∈ stromquistApproxUniquePreferenceSet n μ M α i0 j := by
          refine Set.mem_iUnion.mpr ⟨p, ?_⟩
          simp [hOwner, hxCell]
        have hxUi0 : x ∈ stromquistApproxPreferenceUnion n μ M α i0 :=
          Set.mem_iUnion.mpr ⟨j, hxB⟩
        exact hxU' i0 hxUi0
  choose k z hk using hxBoundary
  have hcard : Fintype.card (Fin (n - 1)) < Fintype.card (Fin n) := by
    simp only [Fintype.card_fin]
    omega
  obtain ⟨j, j', hjj', hkk⟩ := Fintype.exists_ne_map_eq_of_card_lt k hcard
  have hk_j :
      (M : ℝ) * (x ⟨(k j).1, by omega⟩ - α j) = z j :=
    hk j
  have hk_j' :
      (M : ℝ) * (x ⟨(k j).1, by omega⟩ - α j') = z j' := by
    simpa [hkk] using hk j'
  have hsub : (M : ℝ) * (α j - α j') = ((z j' - z j : ℤ) : ℝ) := by
    have hk_j_lin :
        (M : ℝ) * x ⟨(k j).1, by omega⟩ - (M : ℝ) * α j = z j := by
      linarith
    have hk_j'_lin :
        (M : ℝ) * x ⟨(k j).1, by omega⟩ - (M : ℝ) * α j' = z j' := by
      linarith
    have hαj : (M : ℝ) * α j = (M : ℝ) * x ⟨(k j).1, by omega⟩ - z j := by
      linarith
    have hαj' : (M : ℝ) * α j' = (M : ℝ) * x ⟨(k j).1, by omega⟩ - z j' := by
      linarith
    calc
      (M : ℝ) * (α j - α j') = (M : ℝ) * α j - (M : ℝ) * α j' := by ring
      _ = (((M : ℝ) * x ⟨(k j).1, by omega⟩ - z j) -
          ((M : ℝ) * x ⟨(k j).1, by omega⟩ - z j')) := by rw [hαj, hαj']
      _ = (z j' : ℝ) - (z j : ℝ) := by ring
      _ = ((z j' - z j : ℤ) : ℝ) := by rw [Int.cast_sub]
  have hrepr : α j - α j' = ((z j' - z j : ℤ) : ℝ) / M := by
    have hM0 : (M : ℝ) ≠ 0 := by exact_mod_cast (Nat.ne_of_gt hM)
    apply (eq_div_iff hM0).2
    nlinarith [hsub]
  have hirr := (irrational_iff_ne_rational (α j - α j')).mp (hα hjj')
  exact hirr (z j' - z j) M (by exact_mod_cast (Nat.ne_of_gt hM)) hrepr

private theorem stromquist_same_shiftedCell_dist_le
    (hn : 0 < n)
    (M : ℕ) (hM : 0 < M) (α : Fin n → ℝ) (j : Fin n)
    (p : Fin (n - 1) → ℤ) (x y : Fin n → ℝ)
    (hx : x ∈ stromquistShiftedCell n M α j p)
    (hy : y ∈ stromquistShiftedCell n M α j p)
    (hxs : x ∈ stdSimplex ℝ (Fin n)) (hys : y ∈ stdSimplex ℝ (Fin n)) :
    dist x y ≤ n / M := by
  rcases n with _ | m
  · exact Fin.elim0 j
  have hmM_nonneg : 0 ≤ (m : ℝ) / (M : ℝ) := by positivity
  have hcoord : ∀ k : Fin m,
      |x k.castSucc - y k.castSucc| ≤ 1 / (M : ℝ) := by
    intro k
    have hxk := hx k
    have hyk := hy k
    have hMpos : (0 : ℝ) < M := by exact_mod_cast hM
    change |x ⟨k.1, by omega⟩ - y ⟨k.1, by omega⟩| ≤ 1 / (M : ℝ)
    rw [abs_sub_le_iff]
    constructor
    · have hlt : x ⟨k.1, by omega⟩ - y ⟨k.1, by omega⟩ < 1 / (M : ℝ) := by
        rw [lt_div_iff₀ hMpos]
        nlinarith [hxk.2, hyk.1]
      linarith
    · have hlt : y ⟨k.1, by omega⟩ - x ⟨k.1, by omega⟩ < 1 / (M : ℝ) := by
        rw [lt_div_iff₀ hMpos]
        nlinarith [hyk.2, hxk.1]
      linarith
  have hlast :
      |x (Fin.last m) - y (Fin.last m)| ≤ m / (M : ℝ) := by
    calc
      |x (Fin.last m) - y (Fin.last m)|
          ≤ ∑ k : Fin m, |x k.castSucc - y k.castSucc| :=
            Math.Fin.abs_last_sub_last_le_sum_abs_castSucc x y hxs.2 hys.2
      _ ≤ ∑ _k : Fin m, (1 / (M : ℝ)) :=
            Finset.sum_le_sum fun k _ => hcoord k
      _ = m / (M : ℝ) := by
            simp [Finset.sum_const, Finset.card_univ, Fintype.card_fin, nsmul_eq_mul,
              div_eq_mul_inv]
  have hdist_nonneg : 0 ≤ (m.succ : ℝ) / (M : ℝ) := by positivity
  rw [dist_pi_le_iff hdist_nonneg]
  intro i
  by_cases hi : i = Fin.last m
  · subst hi
    simpa [dist_eq_norm] using hlast.trans
      (div_le_div_of_nonneg_right (by norm_num : (m : ℝ) ≤ m + 1) (Nat.cast_nonneg _))
  · obtain ⟨k, hk⟩ := i.eq_castSucc_of_ne_last hi
    subst hk
    simpa [dist_eq_norm] using (hcoord k).trans
      (by
        rw [div_le_div_iff_of_pos_right (by positivity : (0 : ℝ) < M)]
        exact_mod_cast Nat.succ_le_succ (Nat.zero_le m))

